# Ollama Configuration
# Local: http://localhost:11434
# Cloud: https://your-ollama-cloud-endpoint.com
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Server Configuration
HOST=0.0.0.0
PORT=8000

# YouTube Data API v3 — OAuth 2.0 (for caption download)
# Set GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET, then run:
#   python scripts/get_youtube_refresh_token.py
# to obtain YOUTUBE_REFRESH_TOKEN
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=